[Unit]
Description=Digital Audio Mixer (Liquidsoap: RTL-Airband + SDRTrunk -> Icecast)
After=network-online.target scanner-digital.service icecast2.service
Wants=network-online.target scanner-digital.service icecast2.service
Requires=icecast2.service
StartLimitIntervalSec=0

[Service]
Type=simple
EnvironmentFile=-/etc/airband-ui.conf
Nice=10
ExecStart=/usr/bin/python3 /home/willminkoff/scannerproject/scripts/digital-mixer.py
Restart=on-failure
RestartSec=1

[Install]
WantedBy=multi-user.target
